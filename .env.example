# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 端口配置 ====================

# Gateway 端口（host 网络模式，直接监听此端口）
# 单节点部署：使用 18789
# 多节点部署：每个节点使用不同端口（8082, 8083, ...）
OPENCLAW_PORT=18789

# ==================== 时区配置 ====================

TZ=Asia/Shanghai

# ==================== 内存配置（可选）====================

# ⚠️ 注意：默认不限制内存，由 Node.js 自动管理
# 仅在以下情况需要配置：
# - 服务器内存较小（<2GB），需要限制防止 OOM
# - 同一服务器运行多个 OpenClaw 实例，需要分配内存
#
# 容器内存限制（MB）
# 取消注释并根据需要修改：
# CONTAINER_MEMORY_LIMIT=800

# Node.js 堆内存限制（MB）
# 建议设置为容器内存的 50%-60%
# 取消注释并根据需要修改：
# NODE_MEMORY_LIMIT=512

# ==================== 内存配置参考 ====================

# 1.6GB 服务器单实例：
# CONTAINER_MEMORY_LIMIT=600
# NODE_MEMORY_LIMIT=384

# 1.6GB 服务器双实例（每个实例）：
# CONTAINER_MEMORY_LIMIT=400
# NODE_MEMORY_LIMIT=256

# 2GB+ 服务器：
# CONTAINER_MEMORY_LIMIT=1024
# NODE_MEMORY_LIMIT=768

# ==================== 说明 ====================

# ⚠️ 注意：API Keys、模型配置、渠道配置等请统一写入 openclaw.json
# 环境变量仅用于端口、时区等基础配置
#
# openclaw.json 位置：
# - Docker 容器内：/root/.openclaw/openclaw.json
# - 宿主机映射目录：./openclaw/openclaw.json
#
# 配置完成后重启容器：
#   docker compose restart
