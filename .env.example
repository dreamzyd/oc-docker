# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 端口配置 ====================

# Gateway 端口（host 网络模式，直接监听此端口）
# 单节点部署：使用 18789
# 多节点部署：每个节点使用不同端口（8082, 8083, ...）
OPENCLAW_PORT=18789

# ==================== 时区配置 ====================

TZ=Asia/Shanghai

# ==================== 内存配置（重要！）====================

# 容器内存限制（MB）
# 根据服务器物理内存和实例数量调整：
# - 1.6GB 服务器单实例：800
# - 1.6GB 服务器双实例：400（每个实例）
# - 2GB+ 服务器：1024
CONTAINER_MEMORY_LIMIT=800

# Node.js 堆内存限制（MB）
# 建议设置为容器内存的 50%-60%
# - 1.6GB 服务器单实例：512
# - 1.6GB 服务器双实例：256（每个实例）
# - 2GB+ 服务器：768
NODE_MEMORY_LIMIT=512

# ==================== 说明 ====================

# ⚠️ 注意：API Keys、模型配置、渠道配置等请统一写入 openclaw.json
# 环境变量仅用于端口、时区、内存等基础配置
#
# openclaw.json 位置：
# - Docker 容器内：/root/.openclaw/openclaw.json
# - 宿主机映射目录：./openclaw/openclaw.json
#
# 配置完成后重启容器：
#   docker compose restart
