# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 基础配置 ====================

# OpenClaw 镜像版本
OPENCLAW_VERSION=latest

# 默认模型
# 阿里云百炼：bailian/qwen3.5-plus
# Anthropic: anthropic/claude-opus-4-6
# OpenAI: openai/gpt-4o
OPENCLAW_DEFAULT_MODEL=bailian/qwen3.5-plus

# ==================== 端口配置 ====================

# Gateway 端口（host 网络模式，直接监听此端口）
# 单节点部署：使用 18789
# 多节点部署：每个节点使用不同端口（8082, 8083, ...）
OPENCLAW_PORT=18789

# ==================== 时区配置 ====================

TZ=Asia/Shanghai

# ==================== 模型 API Keys（可选）====================

# 阿里云百炼（通义千问）
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 渠道配置（可选）====================

# 飞书（从飞书开发者后台获取）
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxx

# Telegram（从 BotFather 获取）
# TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 其他配置 ====================

# 日志级别（debug, info, warn, error）
OPENCLAW_LOG_LEVEL=info

# 是否启用调试模式
OPENCLAW_DEBUG=false
