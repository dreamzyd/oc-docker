# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 端口配置 ====================

# Gateway 端口（host 网络模式，直接监听此端口）
# 单节点部署：使用 18789
# 多节点部署：每个节点使用不同端口（8082, 8083, ...）
OPENCLAW_PORT=18789

# ==================== 时区配置 ====================

TZ=Asia/Shanghai

# ==================== 说明 ====================

# ⚠️ 注意：API Keys、模型配置、渠道配置等请统一写入 openclaw.json
# 环境变量仅用于端口和时区等基础配置
#
# openclaw.json 位置：
# - Docker 容器内：/root/.openclaw/openclaw.json
# - 宿主机映射目录：./openclaw/openclaw.json
#
# 配置完成后重启容器：
#   docker compose restart
